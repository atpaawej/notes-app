# Neon Postgres
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# Firebase Admin SDK (server-side, both web and mcp)
# In production, these are read directly. In local dev with the service-account
# JSON at secrets/firebase-service-account.json, set GOOGLE_APPLICATION_CREDENTIALS
# instead and the Admin SDK will pick it up automatically.
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# Path to the Firebase Admin SDK service account JSON (local dev only)
GOOGLE_APPLICATION_CREDENTIALS=./secrets/firebase-service-account.json

# Firebase Client SDK (web only, prefix with NEXT_PUBLIC_)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# AgentOnboard partner key (for REST API session-token verification)
AGENTONBOARD_PARTNER_KEY=ao_partner_...

# App URL (for CORS and redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# MCP Server (mcp only)
MCP_PORT=3001